---
import type { WorkItem } from '../data/work';

interface Props {
  item: WorkItem;
}
const { item } = Astro.props;

const dotColor: Record<WorkItem['status'], string> = {
  live: 'var(--dot-live)',
  paused: 'var(--dot-paused)',
  exited: 'var(--dot-ended)',
  closed: 'var(--dot-closed)',
  archived: 'var(--dot-closed)',
};
---

<div class="item">
  <div class="row">
    {item.icon && (
      <a
        class="icon-link"
        href={item.url}
        target="_blank"
        rel="noopener"
        tabindex="-1"
        aria-hidden="true"
      >
        <img class="icon" src={item.icon} alt="" width="22" height="22" />
      </a>
    )}
    <a
      class="name"
      href={item.url}
      target="_blank"
      rel="noopener"
    >{item.name}</a>
    <span class="end">
      <span class="meta">{item.meta}</span>
      <span class="dot" style={`background: ${dotColor[item.status]}`} title={item.status}></span>
    </span>
  </div>
  <div class="desc">{item.description}</div>
</div>

<style>
  .row {
    display: flex;
    align-items: baseline;
    gap: 11px;
  }
  .icon-link {
    flex: 0 0 auto;
    align-self: center;
    line-height: 0;
  }
  .icon-link:hover .icon {
    opacity: 0.6;
  }
  .icon {
    width: 22px;
    height: 22px;
    object-fit: contain;
    /* optical centring: align to the title's cap-height centre, not its line box */
    transform: translateY(-2.5px);
    mix-blend-mode: multiply;
  }
  .name {
    font-family: var(--serif);
    font-size: 21px;
    font-weight: 500;
    text-decoration: none;
  }
  .end {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: 11px;
    white-space: nowrap;
  }
  .meta {
    font-family: var(--mono);
    font-size: 13px;
    color: var(--faint);
  }
  .dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    flex: 0 0 auto;
  }
  .desc {
    font-family: var(--serif);
    font-size: 16px;
    line-height: 1.5;
    color: var(--muted);
    margin-top: 2px;
  }
  @media (max-width: 680px) {
    .row {
      flex-wrap: wrap;
    }
  }
</style>
